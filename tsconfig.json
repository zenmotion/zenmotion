{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "react-native",
    "allowJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["expo-router"]
  },
  "include": [
    "src",
    "app",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
